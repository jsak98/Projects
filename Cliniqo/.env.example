# ============================================================
# CLINIC APP - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clinic_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Google Sheets (for appointment form sync)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Gmail Notifications
# 1. Enable 2FA on your Google account
# 2. Go to myaccount.google.com → Security → App Passwords
# 3. Generate App Password for "Mail" → paste below
GMAIL_SENDER=yourclinic@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Telegram Bot
# Token received from @BotFather when you created your bot
TELEGRAM_BOT_TOKEN=8760534809:AAEFbNQrx9_ORXYDdacEpnlFU0ZqGlguXxo

# App
APP_SECRET_KEY=change_this_to_a_random_secret
